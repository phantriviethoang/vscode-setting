{
    "name": "vscode-setting",
    "displayName": "vscode-setting",
    "description": "vscode-setting",
    "version": "1.0.5",
    "engines": {
        "vscode": "^1.105.0"
    },
    "publisher": "phantriviethoang",
    "repository": {
        "type": "git",
        "url": "https://github.com/phantriviethoang/vscode"
    },
    "icon": "images/icon.png",
    "categories": [
        "Themes"
    ],
    "contributes": {
        "configurationDefaults": {
            "editor.guides.indentation": false,
            "editor.glyphMargin": false,
            "editor.folding": true,
            "editor.renderWhitespace": "none",
            "editor.rulers": [],
            "editor.guides.highlightActiveIndentation": false,
            "breadcrumbs.enabled": true,
            "editor.renderLineHighlight": "none",
            "scm.diffDecorations": "gutter",
            "editor.fontSize": 15,
            "editor.lineHeight": 30,
            "editor.fontFamily": "JetBrains Mono, MonoLisa",
            "editor.fontLigatures": "'ss02",
            "editor.detectIndentation": false,
            "editor.wordWrap": "wordWrapColumn",
            "editor.copyWithSyntaxHighlighting": false,
            "editor.linkedEditing": false,
            "editor.formatOnPaste": true,
            "editor.formatOnSave": true,
            "editor.defaultFormatter": "esbenp.prettier-vscode",
            "editor.autoClosingBrackets": "always",
            "editor.bracketPairColorization.enabled": false,
            "editor.autoClosingQuotes": "always",
            "editor.autoIndent": "advanced",
            "editor.autoIndentOnPaste": true,
            "editor.colorDecorators": false,
            "editor.wordSeparators": "`~!@#%^&*()=+[{]}\\|;:'\",.<>/?",
            "editor.lineNumbers": "off",
            "editor.minimap.enabled": false,
            "editor.minimap.maxColumn": 250,
            "editor.scrollbar.horizontal": "hidden",
            "editor.scrollbar.vertical": "auto",
            "editor.scrollbar.verticalScrollbarSize": 7,
            "editor.codeLens": false,
            "editor.inlayHints.enabled": "off",
            "editor.renderControlCharacters": false,
            "editor.overviewRulerBorder": false,
            "editor.hideCursorInOverviewRuler": true,
            "editor.selectionHighlight": false,
            "editor.semanticHighlighting.enabled": true,
            "editor.occurrencesHighlight": "singleFile",
            "editor.matchBrackets": "never",
            "editor.lightbulb.enabled": "off",
            "editor.padding.top": 10,
            "editor.stickyScroll.enabled": false,
            "editor.cursorSurroundingLines": 5,
            "editor.cursorBlinking": "solid",
            "editor.cursorSmoothCaretAnimation": "on",
            "editor.smoothScrolling": true,
            "editor.tabCompletion": "on",
            "editor.suggestFontSize": 16,
            "editor.suggestLineHeight": 30,
            "editor.quickSuggestions": {
                "strings": true,
                "other": true
            },
            "editor.quickSuggestionsDelay": 0,
            "editor.screenReaderAnnounceInlineSuggestion": false,
            "editor.accessibilitySupport": "off",
            "editor.acceptSuggestionOnCommitCharacter": false,
            "editor.acceptSuggestionOnEnter": "off",
            "editor.multiCursorModifier": "alt",
            "editor.gotoLocation.multipleReferences": "goto",
            "editor.gotoLocation.multipleDefinitions": "goto",
            "editor.gotoLocation.multipleDeclarations": "goto",
            "editor.gotoLocation.multipleImplementations": "goto",
            "editor.gotoLocation.multipleTypeDefinitions": "goto",
            "workbench.startupEditor": "none",
            "workbench.tips.enabled": false,
            "workbench.activityBar.location": "hidden",
            "workbench.sideBar.location": "right",
            "workbench.tree.indent": 12,
            "workbench.tree.enableStickyScroll": false,
            "workbench.tree.renderIndentGuides": "none",
            "workbench.list.smoothScrolling": true,
            "workbench.secondarySideBar.defaultVisibility": "hidden",
            "workbench.secondarySideBar.showLabels": false,
            "workbench.quickOpen.closeOnFocusLost": false,
            "workbench.layoutControl.enabled": false,
            "workbench.panel.showLabels": false,
            "workbench.editor.editorActionsLocation": "hidden",
            "workbench.navigationControl.enabled": false,
            "window.commandCenter": false,
            "workbench.iconTheme": "Icon",
            "workbench.productIconTheme": "feather-icons",
            "workbench.editor.scrollToSwitchTabs": true,
            "workbench.editor.decorations.badges": false,
            "workbench.editor.decorations.colors": false,
            "workbench.editor.enablePreviewFromCodeNavigation": true,
            "workbench.editor.highlightModifiedTabs": true,
            "workbench.editor.pinnedTabSizing": "compact",
            "workbench.editor.showTabs": "none",
            "workbench.statusBar.visible": false,
            "window.newWindowDimensions": "inherit",
            "window.density.editorTabHeight": "compact",
            "window.menuBarVisibility": "toggle",
            "window.customTitleBarVisibility": "never",
            "files.autoSave": "afterDelay",
            "files.autoSaveDelay": 500,
            "files.trimTrailingWhitespace": true,
            "files.insertFinalNewline": true,
            "files.trimFinalNewlines": true,
            "files.associations": {
                ".php_cs": "php",
                ".php_cs.dist": "php"
            },
            "fileutils.inputBox.pathType": "workspace",
            "fileutils.moveFile.typeahead.enabled": true,
            "explorer.compactFolders": false,
            "explorer.confirmDragAndDrop": false,
            "explorer.confirmPasteNative": false,
            "explorer.confirmDelete": false,
            "explorer.fileNesting.enabled": false,
            "search.searchOnType": false,
            "search.smartCase": true,
            "search.useIgnoreFiles": false,
            "search.exclude": {
                "**/node_modules": true,
                "**/bower_components": true,
                "**/*.code-search": true,
                "vendor/": true,
                "resources/views/vendor/**": false,
                "resources/js/actions/**": true,
                "resources/js/routes/**": true,
                "resources/js/wayfinder/**": true,
                "**/dist": true,
                "**/_ide_helper.php": true,
                "**/composer.lock": true,
                "**/package-lock.json": true,
                "storage/framework/views": true,
                ".phpunit.result.cache": true
            },
            "terminal.integrated.initialHint": false,
            "terminal.integrated.commandsToSkipShell": [
                "workbench.view.scm"
            ],
            "terminal.integrated.cursorWidth": 2,
            "terminal.integrated.fontSize": 15,
            "terminal.integrated.lineHeight": 1.2,
            "terminal.integrated.fontFamily": "JetBrains Mono, MonoLisa",
            "terminal.integrated.enableMultiLinePasteWarning": "never",
            "terminal.integrated.suggest.enabled": true,
            "terminal.integrated.suggest.showStatusBar": false,
            "terminal.integrated.tabs.location": "left",
            "terminal.integrated.cursorStyle": "block",
            "terminal.integrated.smoothScrolling": true,
            "terminal.integrated.stickyScroll.enabled": false,
            "terminal.integrated.fontLigatures.enabled": true,
            "terminal.integrated.shellIntegration.decorationsEnabled": "never",
            "terminal.integrated.tabs.title": "${cwdFolder}",
            "diffEditor.hideUnchangedRegions.enabled": true,
            "diffEditor.useInlineViewWhenSpaceIsLimited": false,
            "diffEditor.ignoreTrimWhitespace": false,
            "diffEditor.wordWrap": "on",
            "git.confirmSync": false,
            "problems.decorations.enabled": false,
            "chat.commandCenter.enabled": false,
            "chat.editor.wordWrap": "on",
            "chat.agent.enabled": false,
            "chat.disableAIFeatures": true,
            "chat.extensionUnification.enabled": false,
            "security.workspace.trust.untrustedFiles": "open",
            "extensions.ignoreRecommendations": true,
            "emmet.triggerExpansionOnTab": true,
            "emmet.includeLanguages": {
                "blade": "html",
                "vue-html": "html",
                "vue": "html",
                "react": "html",
                "javascript": "html"
            },
            "php.suggest.basic": false,
            "php.format.codeStyle": "Laravel",
            "php.format.rules.spaceBeforeParenthesesInArrowFunctions": true,
            "php.format.rules.addCommaAfterLastArrayElement": false,
            "php.format.rules.blankLinesAfterOpenTag": 1,
            "php.format.rules.endWithNewLine": true,
            "php.format.rules.openBraceOnNewLineForAnonymousClasses": true,
            "php.format.rules.spaceBeforeColonInControlStatements": true,
            "php.format.rules.spaceBeforeColonInReturnType": false,
            "php.format.rules.spaceAfterUnaryNot": true,
            "javascript.suggest.paths": false,
            "typescript.suggest.paths": false,
            "html.format.extraLiners": "nul",
            "vetur.format.options.tabSize": 4,
            "vetur.format.options.useTabs": true,
            "vetur.format.defaultFormatter.ts": "vscode-typescript",
            "vetur.format.defaultFormatter.html": "js-beautify-html",
            "prettier.tabWidth": 4,
            "prettier.useTabs": true,
            "prettier.singleAttributePerLine": true,
            "tailwindCSS.includeLanguages": {
                "plaintext": "html"
            },
            "tailwindCSS.experimental.configFile": null,
            "auto-rename-tag.activationOnLanguage": [
                "*"
            ],
            "blade.format.enable": true,
            "blade.format.wrapAttributes": "auto",
            "liveServer.settings.CustomBrowser": "firefox",
            "quokka.automaticRestart": true,
            "quokka.fontSize": 16,
            "quokka.showOutputOnStart": false,
            "quokka.useOutputPanel": false,
            "vim.cursorStylePerMode.insert": "line",
            "vim.cursorStylePerMode.visual": "block",
            "vim.cursorStylePerMode.visualline": "block",
            "vim.cursorStylePerMode.visualblock": "block",
            "vim.camelCaseMotion.enable": true,
            "vim.easymotion": true,
            "vim.easymotionDimColor": "#bcbec4a8",
            "vim.easymotionIncSearchForegroundColor": "#BCBEC4",
            "vim.easymotionKeys": "asdfghjklewcmp",
            "vim.easymotionMarkerForegroundColorOneChar": "#FFAE8F",
            "vim.easymotionMarkerForegroundColorTwoCharFirst": "#EB6689",
            "vim.easymotionMarkerForegroundColorTwoCharSecond": "#ffdd77",
            "vim.foldfix": true,
            "vim.highlightedyank.color": "#44475a",
            "vim.highlightedyank.enable": true,
            "vim.hlsearch": true,
            "vim.joinspaces": false,
            "vim.leader": "<space>",
            "vim.registers.useClipboard": true,
            "vim.replaceWithRegister": true,
            "vim.sneak": true,
            "vim.sneakUseIgnorecaseAndSmartcase": true,
            "vim.timeout": 700,
            "vim.useSystemClipboard": true,
            "vim.visualstar": true,
            "vim.vimrc.path": "~/.vimrc",
            "vim.vimrc.enable": true,
            "vim.handleKeys": {
                "<C-b>": true,
                "<C-c>": true,
                "<C-d>": true,
                "<C-h>": true,
                "<C-j>": true,
                "<C-m>": true,
                "<C-t>": true,
                "<C-v>": true
            },
            "vim.normalModeKeyBindings": [
                {
                    "before": [
                        "<leader>",
                        "1"
                    ],
                    "commands": [
                        "workbench.action.toggleSidebarVisibility"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "g"
                    ],
                    "commands": [
                        "workbench.action.navigateLast"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "l"
                    ],
                    "commands": [
                        "workbench.action.quickOpenPreviousRecentlyUsedEditor"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "m"
                    ],
                    "commands": [
                        "editor.emmet.action.matchTag"
                    ]
                },
                {
                    "before": [
                        "g",
                        ";"
                    ],
                    "commands": [
                        "editor.action.openLink"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "i"
                    ],
                    "commands": [
                        "editor.emmet.action.selectNextItem"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "o"
                    ],
                    "commands": [
                        "editor.emmet.action.selectPrevItem"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "u"
                    ],
                    "commands": [
                        "editor.emmet.action.updateTag"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "t"
                    ],
                    "commands": [
                        "editor.emmet.action.splitJoinTag"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "s"
                    ],
                    "commands": [
                        "workbench.action.files.save"
                    ],
                    "silent": true
                },
                {
                    "before": [
                        "<leader>",
                        "p"
                    ],
                    "commands": [
                        "workbench.action.quickOpen"
                    ],
                    "silent": true
                },
                {
                    "before": [
                        "<leader>",
                        "h"
                    ],
                    "commands": [
                        "editor.action.showHover"
                    ],
                    "silent": true
                },
                {
                    "before": [
                        "<leader>",
                        "f"
                    ],
                    "commands": [
                        "editor.action.formatSelection.multiple"
                    ]
                }
            ],
            "vim.visualModeKeyBindingsNonRecursive": [
                {
                    "before": [
                        "<leader>",
                        "m"
                    ],
                    "commands": [
                        "editor.emmet.action.matchTag"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "i"
                    ],
                    "commands": [
                        "editor.emmet.action.selectNextItem"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "o"
                    ],
                    "commands": [
                        "editor.emmet.action.selectPrevItem"
                    ]
                },
                {
                    "before": [
                        "<leader>",
                        "f"
                    ],
                    "commands": [
                        "editor.action.formatSelection.multiple"
                    ]
                }
            ],
            "[javascriptreact]": {
                "editor.defaultFormatter": "vscode.typescript-language-features"
            },
            "[html]": {
                "editor.defaultFormatter": "vscode.html-language-features"
            },
            "[css]": {
                "editor.defaultFormatter": "vscode.css-language-features"
            },
            "[javascript]": {
                "editor.defaultFormatter": "vscode.typescript-language-features"
            },
            "[typescriptreact]": {
                "editor.defaultFormatter": "vscode.typescript-language-features"
            },
            "[blade]": {
                "editor.defaultFormatter": "onecentlin.laravel-blade"
            },
            "[typescript]": {
                "editor.defaultFormatter": "vscode.typescript-language-features"
            },
            "[vue]": {
                "editor.defaultFormatter": "Wscats.vue"
            },
            "[php]": {
                "editor.defaultFormatter": "laravel.vscode-laravel"
            },
            "[snippets]": {
                "editor.defaultFormatter": "vscode.json-language-features"
            },
            "vscode_custom_css.imports": [
                "file://${userHome}/.config/Code/custom.css",
                "file://${userHome}/.config/Code/custom.js"
            ],
            "sqlite3-editor.ui.minimizePanel": true,
            "vue.autoInsert.dotValue": true,
            "vue.editor.templateInterpolationDecorators": false,
            "vue.format.wrapAttributes": "force-expand-multiline",
            "vue3snippets.tabWidth": 4,
            "vue3snippets.semi": false,
            "vue3snippets.singleQuote": true,

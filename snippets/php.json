{
    "PHP open tag inline": {
        "prefix": "pt",
        "body": [
            "<?php $0 ?>"
        ],
        "description": "PHP open and close tags on one line"
    },
    "PHP echo simple": {
        "prefix": "ek",
        "body": [
            "echo $1;"
        ],
        "description": "Echo simple statement"
    },
    "PHP echo string": {
        "prefix": "ec",
        "body": [
            "echo \"$1\";"
        ],
        "description": "Echo String statement"
    },
    "PHP echo variable": {
        "prefix": "ev",
        "body": [
            "echo $$1;"
        ],
        "description": "Echo Variable statement"
    },
    "PHP declare variable": {
        "prefix": "va",
        "body": [
            "$$1;"
        ],
        "description": "PHP declare variable"
    },
    "Var Dump": {
        "prefix": "vd",
        "body": [
            "var_dump($1);"
        ],
        "description": "Var Dump dd function"
    },
    "PHP Function": {
        "prefix": "fnc",
        "body": [
            "function ${1:}($${2:$param}) {",
            "    ${3:// code...}",
            "}"
        ],
        "description": "PHP function declaration"
    },
